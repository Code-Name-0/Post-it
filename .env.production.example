# Production environment variables for Railway
# Copy these values to your Railway environment settings

NODE_ENV=production
PORT=3000
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/social-postit?retryWrites=true&w=majority
JWT_SECRET=your_generated_secret_key_min_32_chars
CLIENT_URL=https://your-railway-app-url.railway.app
