# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB URI (use MongoDB Atlas for production)
# Example: mongodb+srv://username:password@cluster.mongodb.net/social-postit
MONGO_URI=mongodb://localhost:27017/social-postit

# ── Authentication ────────────────────────────────────────────────────────────────
# JWT secret (min 32 chars) — generate with: openssl rand -hex 32
JWT_SECRET=change_this_secret_key_in_production_min_32_chars

# ── Environment ──────────────────────────────────────────────────────────────────
# Set to 'production' on Railway/Heroku
NODE_ENV=development

# ── Ports ────────────────────────────────────────────────────────────────────────
PORT=3001
HTTPS_PORT=3443

# ── Frontend (optional - only needed if frontend is separate) ────────────────────
# In production with this setup, leave empty or use Railway domain
CLIENT_URL=http://localhost:5173

# ── SSL Certificates (development only) ───────────────────────────────────────────
# Generate with: openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
#   -keyout certs/key.pem -out certs/cert.pem -subj "/CN=localhost"
SSL_KEY_PATH=./certs/key.pem
SSL_CERT_PATH=./certs/cert.pem

